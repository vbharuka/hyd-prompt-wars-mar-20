// Firebase Storage Security Rules for Med-Link MVP
// Deploy with: firebase deploy --only storage
//
// Each user can only read/write their own scan images.
// Path structure: scans/{userId}/{timestamp}-{filename}.webp

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /scans/{userId}/{fileName} {
      // Only the authenticated owner can read or write their own images
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Deny all other paths by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
